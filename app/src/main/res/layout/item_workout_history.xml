<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <!-- Title -->
    <TextView
        android:id="@+id/workoutTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Workout Title"
        android:textStyle="bold"
        android:textSize="18sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/expandButton"
        app:layout_constraintHorizontal_bias="0.0" />

    <!-- Date -->
    <TextView
        android:id="@+id/workoutDate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Workout Date"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/workoutTitle"
        app:layout_constraintStart_toStartOf="@id/workoutTitle"
        app:layout_constraintEnd_toEndOf="@id/workoutTitle"
        app:layout_constraintBottom_toTopOf="@id/exerciseRecyclerView"
        android:layout_marginBottom="8dp" />

    <!-- Expand Button -->
    <ImageButton
        android:id="@+id/expandButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_arrow_down"
        android:contentDescription="Expand workout history"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintTop_toTopOf="@id/workoutTitle"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- RecyclerView (initially hidden) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/exerciseRecyclerView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        tools:listitem="@layout/item_exercise"
        app:layout_constraintTop_toBottomOf="@id/workoutDate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
