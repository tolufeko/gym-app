<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Main theme using MaterialComponents -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- MaterialComponents mandatory colors -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSurface">@color/white</item>

        <!-- Bottom Navigation Style -->
        <item name="bottomNavigationStyle">@style/BottomNavStyle</item>
    </style>

    <!-- Bottom Navigation Customization -->
    <style name="BottomNavStyle" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconTint">@color/selector_bottom_nav</item>
        <item name="itemTextColor">@color/selector_bottom_nav</item>
    </style>
</resources>
